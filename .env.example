# ─────────────────────────────────────────────────────────────────
# .env.example  →  Copy this to `.env` and fill in your values.
#
# NEVER commit the actual `.env` file to git.
# Add `.env` to your `.gitignore`.
# ─────────────────────────────────────────────────────────────────

# ── Groq API ──────────────────────────────────────────────────────
# Get your free key from: https://console.groq.com
GROQ_API_KEY=gsk_your_key_here

# ── Flask ─────────────────────────────────────────────────────────
FLASK_ENV=development           # Change to "production" when deploying
FLASK_SECRET_KEY=change-this-to-a-long-random-string

# ── Database Paths ────────────────────────────────────────────────
# SQLite: stores user profiles + chat history
SQLITE_DB_PATH=data/academic_sanctuary.db

# ChromaDB: stores NCERT embeddings (vector store)
CHROMA_DB_PATH=data/chroma_store

# ── RAG Settings ──────────────────────────────────────────────────
# How many NCERT chunks to retrieve per question
RAG_TOP_K=4

# ── LLM Settings ─────────────────────────────────────────────────
GROQ_MODEL=llama-3.1-70b-versatile
LLM_MAX_TOKENS=1024
LLM_TEMPERATURE=0.3
